# OS-APOW Environment Configuration
# Copy this file to .env and fill in your values

# Required Environment Variables (per Simplification Report S-3)

# GitHub App installation token for API access
GITHUB_TOKEN=your_github_app_installation_token_here

# Target organization name (e.g., "intel-agency")
GITHUB_ORG=your_organization_name

# Target repository name (e.g., "workflow-orchestration-queue-foxtrot54")
GITHUB_REPO=your_repository_name

# Bot account login for assign-then-verify locking
# This should be the GitHub username of the bot account that will be assigned to issues
SENTINEL_BOT_LOGIN=your_bot_username

# Optional Environment Variables

# HMAC secret for webhook payload verification
# If not set, signature verification is skipped (not recommended for production)
WEBHOOK_SECRET=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Sentinel polling interval in seconds
SENTINEL_POLL_INTERVAL=60

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=300
